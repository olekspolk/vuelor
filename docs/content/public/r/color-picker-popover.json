{
  "$schema": "https://shadcn-vue.com/schema/registry-item.json",
  "name": "color-picker-popover",
  "title": "Color Picker (Popover)",
  "author": "Vuelor <https://vuelor.dev>",
  "description": "Hex input that opens a Reka UI popover containing a canvas, eyedropper and sliders.",
  "dependencies": [
    "@vuelor/picker@^1.0.1",
    "reka-ui"
  ],
  "registryDependencies": [
    "@vuelor/color-picker-theme"
  ],
  "files": [
    {
      "path": "registry/default/color-picker-popover/ColorPickerPopover.vue",
      "content": "<script lang=\"ts\" setup>\nimport { useTemplateRef } from 'vue'\nimport { useForwardPropsEmits } from 'reka-ui'\nimport {\n  ColorPickerRoot,\n  ColorPickerCanvas,\n  ColorPickerEyeDropper,\n  ColorPickerSliderHue,\n  ColorPickerSliderAlpha,\n  ColorPickerInputHex,\n  ColorPickerSwatch,\n  type ColorPickerRootProps,\n  type ColorPickerRootEmits\n} from '@vuelor/picker'\nimport {\n  PopoverContent,\n  PopoverPortal,\n  PopoverRoot,\n  PopoverTrigger\n} from 'reka-ui'\n\ntype ColorPickerProps = Omit<ColorPickerRootProps, 'styling' | 'ui'>\n\nconst props = defineProps<ColorPickerProps>()\nconst emits = defineEmits<ColorPickerRootEmits>()\n\nconst forwarded = useForwardPropsEmits(props, emits)\n\nconst colorPicker = useTemplateRef<typeof ColorPickerRoot>('colorPicker')\n</script>\n\n<template>\n  <ColorPickerRoot\n    ref=\"colorPicker\"\n    class=\"p-0 rounded-none bg-transparent !shadow-none w-auto\"\n    :ui=\"{\n      shared: { thumb: 'border-2 h-3 w-3' },\n      slider: { track: 'h-3' },\n      input: { item: 'bg-white', field: 'max-w-16' }\n    }\"\n    v-bind=\"forwarded\"\n  >\n    <PopoverRoot>\n      <ColorPickerInputHex class=\"w-52 shadow bg-vuelor-input rounded-[5px]\" >\n        <template #before>\n          <PopoverTrigger as-child>\n            <ColorPickerSwatch :value=\"colorPicker?.color.hexa.value ?? '#B63DDAFF'\" />\n          </PopoverTrigger>\n        </template>\n      </ColorPickerInputHex>\n\n      <PopoverPortal>\n        <PopoverContent\n          align=\"start\"\n          :sideOffset=\"5\"\n          :alignOffset=\"-4\"\n          class=\"bg-white rounded-[5px] shadow-vuelor-card\"\n        >\n          <ColorPickerCanvas :ui=\"{ root: 'w-52 rounded-none rounded-t-[5px]' }\" />\n          <div class=\"p-3 flex items-center gap-3\">\n            <ColorPickerEyeDropper>\n              <svg width=\"24\" height=\"24\" fill=\"none\" viewBox=\"0 0 24 24\">\n                <path\n                  fill=\"currentColor\"\n                  fill-rule=\"evenodd\"\n                  clip-rule=\"evenodd\"\n                  d=\"M17.52 6.471a1.62 1.62 0 0 0-2.295.003l-1.87 1.88-.354.355-.355-.354-.01-.01a.9.9 0 0 0-1.272 0l-.02.02a.9.9 0 0 0 0 1.273l.51.51 2 2 .51.51a.9.9 0 0 0 1.272 0l.02-.02a.9.9 0 0 0 0-1.273l-.01-.01-.352-.353.351-.353 1.879-1.888a1.62 1.62 0 0 0-.003-2.29m-3.004-.702a2.621 2.621 0 1 1 3.717 3.697l-1.57 1.579a1.9 1.9 0 0 1-.3 2.3l-.02.02a1.9 1.9 0 0 1-2.687 0l-.156-.157-5.647 5.642a.5.5 0 0 1-.353.147H5.504a.5.5 0 0 1-.5-.5L5 16.503a.5.5 0 0 1 .146-.354l5.647-5.647-.157-.156a1.9 1.9 0 0 1 0-2.687l.02-.02a1.9 1.9 0 0 1 2.299-.3zm-3.016 5.44 1.293 1.292-5.5 5.496h-1.29L6 16.707z\"\n                />\n              </svg>\n            </ColorPickerEyeDropper>\n            <div class=\"flex flex-col flex-1 gap-2\">\n              <ColorPickerSliderHue />\n              <ColorPickerSliderAlpha />\n            </div>\n          </div>\n        </PopoverContent>\n      </PopoverPortal>\n    </PopoverRoot>\n  </ColorPickerRoot>\n</template>\n",
      "type": "registry:component"
    }
  ],
  "meta": {
    "vuelorVersion": "^1.0.1",
    "stylingMode": "tailwindcss"
  },
  "docs": "Tailwind v4 (shadcn-vue default): the required vuelor-* tokens are installed automatically via the color-picker-theme registry dependency. Tailwind v3 only: add './node_modules/@vuelor/picker/dist/index.js' to your tailwind.config content array so the vuelor-* utility classes are not purged. Non-Tailwind projects: set styling=\"vanillacss\" on ColorPickerRoot and import '@vuelor/picker/style.css'.",
  "categories": [
    "color-picker",
    "form",
    "input"
  ],
  "type": "registry:block"
}