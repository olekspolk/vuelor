{
  "$schema": "https://shadcn-vue.com/schema/registry-item.json",
  "name": "color-picker-tabs-vertical",
  "title": "Color Picker (Tabs, Vertical)",
  "author": "Vuelor <https://vuelor.dev>",
  "description": "Tabbed color picker with a vertical slider layout.",
  "dependencies": [
    "@vuelor/picker@^1.0.1",
    "reka-ui"
  ],
  "registryDependencies": [
    "@vuelor/color-picker-theme"
  ],
  "files": [
    {
      "path": "registry/default/color-picker-tabs-vertical/ColorPickerWithTabsVerticalSliders.vue",
      "content": "<script lang=\"ts\" setup>\nimport { ref, computed } from 'vue'\nimport { useForwardPropsEmits } from 'reka-ui'\nimport { TabsRoot, TabsList, TabsTrigger } from 'reka-ui'\nimport {\n  ColorPickerRoot,\n  ColorPickerCanvas,\n  ColorPickerEyeDropper,\n  ColorPickerSliderHue,\n  ColorPickerSliderAlpha,\n  ColorPickerInputHex,\n  ColorPickerInputHSL,\n  ColorPickerInputRGB,\n  ColorPickerInputHSB,\n  ColorPickerSwatch,\n  type ColorPickerRootProps,\n  type ColorPickerRootEmits\n} from '@vuelor/picker'\n\ntype ColorPickerProps = Omit<ColorPickerRootProps, 'styling' | 'ui'>\n\nconst props = defineProps<ColorPickerProps>()\nconst emits = defineEmits<ColorPickerRootEmits>()\n\nconst forwarded = useForwardPropsEmits(props, emits)\n\nconst INPUTS = {\n  hex: ColorPickerInputHex,\n  rgb: ColorPickerInputRGB,\n  hsl: ColorPickerInputHSL,\n  hsb: ColorPickerInputHSB\n}\n\nconst format = ref<string>('rgb')\n\nconst canvasType = computed<'HSL' | 'HSV'>(() => {\n  return format.value === 'hsl' ? 'HSL' : 'HSV'\n})\n\nconst swatches = ref<string[]>([\n  '#FF690050',\n  '#FCB900FF',\n  '#7BDCB5FF',\n  '#00D084FF',\n  '#8ED1FCFF',\n  '#0693E3FF',\n  '#ABB8C344',\n  '#EB144CFF',\n  '#F78DA7FF',\n  '#9900EFFF',\n  '#F6BD6044',\n  '#84A59DBA',\n])\n\n\n</script>\n\n<template>\n  <ColorPickerRoot\n    class=\"w-[295px] p-0 gap-0\"\n    :ui=\"{\n      input: {\n        group: '!outline-none gap-2',\n        item: '!rounded-[6px] hover:outline-1 outline-vuelor-border focus-within:outline-1 focus-within:outline-vuelor-primary'\n      },\n      shared: {\n        thumb: 'border-[3px] w-3.5 h-3.5'\n      },\n      canvas: {\n        root: 'rounded-lg'\n      },\n      slider: {\n        track: 'w-4'\n      }\n    }\"\n    v-bind=\"forwarded\"\n  >\n    <div class=\"pt-4 px-4 pb-3 flex flex-col gap-3\">\n      <div class=\"flex gap-3\">\n        <ColorPickerCanvas :type=\"canvasType\" />\n        <ColorPickerSliderHue orientation=\"vertical\" />\n        <ColorPickerSliderAlpha orientation=\"vertical\" />\n      </div>\n      <TabsRoot\n        v-model=\"format\"\n        default-value=\"hex\"\n      >\n        <TabsList class=\"grid grid-cols-4 items-center justify-center rounded-[7px] bg-vuelor-input p-0.5 w-full\">\n          <TabsTrigger class=\"h-6 inline-flex items-center justify-center rounded-[5px] px-1 py-0.5 text-[11px] font-medium focus-within:outline-1 focus-within:outline-vuelor-primary disabled:pointer-events-none disabled:opacity-50 data-[state=active]:bg-white data-[state=active]:shadow\" value=\"hex\">Hex</TabsTrigger>\n          <TabsTrigger class=\"h-6 inline-flex items-center justify-center rounded-[5px] px-1 py-0.5 text-[11px] font-medium focus-within:outline-1 focus-within:outline-vuelor-primary disabled:pointer-events-none disabled:opacity-50 data-[state=active]:bg-white data-[state=active]:shadow\" value=\"rgb\">RGB</TabsTrigger>\n          <TabsTrigger class=\"h-6 inline-flex items-center justify-center rounded-[5px] px-1 py-0.5 text-[11px] font-medium focus-within:outline-1 focus-within:outline-vuelor-primary disabled:pointer-events-none disabled:opacity-50 data-[state=active]:bg-white data-[state=active]:shadow\" value=\"hsl\">HSL</TabsTrigger>\n          <TabsTrigger class=\"h-6 inline-flex items-center justify-center rounded-[5px] px-1 py-0.5 text-[11px] font-medium focus-within:outline-1 focus-within:outline-vuelor-primary disabled:pointer-events-none disabled:opacity-50 data-[state=active]:bg-white data-[state=active]:shadow\" value=\"hsb\">HSB</TabsTrigger>\n        </TabsList>\n      </TabsRoot>\n      <div class=\"flex items-center gap-3\">\n        <ColorPickerEyeDropper class=\"p-0\">\n          <svg width=\"24\" height=\"24\" fill=\"none\" viewBox=\"0 0 24 24\">\n            <path\n              fill=\"currentColor\"\n              fill-rule=\"evenodd\"\n              clip-rule=\"evenodd\"\n              d=\"M17.52 6.471a1.62 1.62 0 0 0-2.295.003l-1.87 1.88-.354.355-.355-.354-.01-.01a.9.9 0 0 0-1.272 0l-.02.02a.9.9 0 0 0 0 1.273l.51.51 2 2 .51.51a.9.9 0 0 0 1.272 0l.02-.02a.9.9 0 0 0 0-1.273l-.01-.01-.352-.353.351-.353 1.879-1.888a1.62 1.62 0 0 0-.003-2.29m-3.004-.702a2.621 2.621 0 1 1 3.717 3.697l-1.57 1.579a1.9 1.9 0 0 1-.3 2.3l-.02.02a1.9 1.9 0 0 1-2.687 0l-.156-.157-5.647 5.642a.5.5 0 0 1-.353.147H5.504a.5.5 0 0 1-.5-.5L5 16.503a.5.5 0 0 1 .146-.354l5.647-5.647-.157-.156a1.9 1.9 0 0 1 0-2.687l.02-.02a1.9 1.9 0 0 1 2.299-.3zm-3.016 5.44 1.293 1.292-5.5 5.496h-1.29L6 16.707z\"\n            />\n          </svg>\n        </ColorPickerEyeDropper>\n        <component :is=\"INPUTS[format]\" />\n      </div>\n    </div>\n    <div class=\"border-t p-4 grid grid-cols-12 gap-y-1.5\">\n      <ColorPickerSwatch\n        v-for=\"color in swatches\"\n        :value=\"color\"\n        class=\"m-1\"\n      />\n    </div>\n  </ColorPickerRoot>\n</template>\n",
      "type": "registry:component"
    }
  ],
  "meta": {
    "vuelorVersion": "^1.0.1",
    "stylingMode": "tailwindcss"
  },
  "docs": "Tailwind v4 (shadcn-vue default): the required vuelor-* tokens are installed automatically via the color-picker-theme registry dependency. Tailwind v3 only: add './node_modules/@vuelor/picker/dist/index.js' to your tailwind.config content array so the vuelor-* utility classes are not purged. Non-Tailwind projects: set styling=\"vanillacss\" on ColorPickerRoot and import '@vuelor/picker/style.css'.",
  "categories": [
    "color-picker",
    "form",
    "input"
  ],
  "type": "registry:block"
}